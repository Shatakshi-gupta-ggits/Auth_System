## Copy this file to ".env" and fill values
## NEVER commit your real .env

PORT=3000
COOKIE_SECRET=replace-with-strong-secret

# Preferred: single connection string
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.2makqzt.mongodb.net/loginreg_db?retryWrites=true&w=majority

# Optional (only used if MONGO_URI is not set)
MONGO_HOST=cluster0.2makqzt.mongodb.net
MONGO_DB=loginreg_db
MONGO_USER=<db_username>
MONGO_PASSWORD=<db_password>
